{
  "name": "rymetry-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.9",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "bun test src",
    "test:coverage": "bun test src --coverage --coverage-reporter=lcov && bun scripts/check-coverage.ts",
    "perf:lighthouse": "npx lighthouse ${LIGHTHOUSE_URL:-http://localhost:3000} --output=html --output-path=.lighthouse/report.html --chrome-flags=--headless",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,json}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hast-util-sanitize": "^5.0.2",
    "hast-util-to-string": "^3.0.1",
    "lucide-react": "^1.23.0",
    "microcms-js-sdk": "^3.4.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-parse": "^9.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/global": "^5.0.0",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "bun-types": "^1.3",
    "eslint": "^10",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.4.6",
    "lefthook": "^2.1.9",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
